# Trend Intelligence System Configuration

# Reddit API (required for Reddit collector)
# Get credentials at: https://www.reddit.com/prefs/apps
# 1. Click "create another app..."
# 2. Select "script" type
# 3. Fill in name and redirect URI (use http://localhost:8080)
# 4. Copy client_id (under app name) and client_secret
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=CzarTrendMonitor/1.0

# ─── Backend ───

# Supabase (required for data storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# OpenRouter API (for LLM summaries)
# Get API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# Note: Hacker News API is public and requires no authentication
